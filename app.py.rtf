    def fetch_knesset_data():\
        url = "https://knesset.gov.il/Odata/ParliamentInfo.svc/KNS_Agenda"\
        params = \{\
            '$filter': "StartDate ge datetime'" + datetime.now().strftime('%Y-%m-%dT00:00:00') + "'",\
            '$orderby': "StartDate asc",\
            '$format': "json"\
        \}\
        try:\
            response = requests.get(url, params=params)\
            if response.status_code == 200:\
                events = []\
                for item in response.json().get('value', []):\
                    title = item.get('CommitteeSessionName', '') or item.get('Subject', '') or ''\
                    committee = item.get('CommitteeName', '\uc0\u1493 \u1506 \u1491 \u1492  \u1499 \u1500 \u1500 \u1497 \u1514 ')\
                    \
                    if any(word in title for word in KEYWORDS):\
                        events.append(\{\
                            "\uc0\u1502 \u1511 \u1493 \u1512 ": "\u55356 \u57307 \u65039  \u1499 \u1504 \u1505 \u1514  \u1497 \u1513 \u1512 \u1488 \u1500 ",\
                            "\uc0\u1511 \u1496 \u1490 \u1493 \u1512 \u1497 \u1492 ": committee,\
                            "\uc0\u1499 \u1493 \u1514 \u1512 \u1514 ": title,\
                            "\uc0\u1514 \u1488 \u1512 \u1497 \u1498 ": datetime.strptime(item['StartDate'], '%Y-%m-%dT%H:%M:%S').strftime('%d/%m/%Y %H:%M'),\
                            "\uc0\u1506 \u1491 \u1497 \u1508 \u1493 \u1514 ": "\u55357 \u56613  \u1490 \u1489 \u1493 \u1492 \u1492 " if committee in PRIORITY_COMMITTEES else "\u55357 \u56629  \u1512 \u1490 \u1497 \u1500 \u1492 ",\
                            "\uc0\u1511 \u1497 \u1513 \u1493 \u1512 ": "https://main.knesset.gov.il/Activity/committees/Pages/AllCommitteesAgendas.aspx"\
